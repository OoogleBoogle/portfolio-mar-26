---
import Layout from '../layouts/Layout.astro';
import BigCta from '../components/big-cta.astro';
---

<Layout title="Simon Attfield — Portfolio" activePage="home">

  <!-- Hero Section: Digital Gig Poster -->
  <section class="hero">
    <div class="hero__container">
      <div class="hero__grid">

        <!-- Left Column: Ransom Note Typography -->
        <div class="hero__left">
          <div class="hero__tape-strip"></div>

          <h1 class="hero__name">
            <span class="hero__name-first" style="--rot: -2deg">SIMON</span><br />
            <span class="hero__name-last" style="--rot: 1deg">ATTFIELD</span>
          </h1>

          <div class="hero__ethos-block">
            <div class="hero__ethos-inner">
              <div class="hero__halftone"></div>

              <h2 class="hero__sub-headline">8+ YEARS OF FRONT-END ANARCHY</h2>

              <div class="hero__xerox-block">
                <div class="hero__xerox-tint"></div>
                <h3 class="hero__xerox-title">THE CODE IS THE MESSAGE.</h3>
                <p class="hero__xerox-body">
                  If a site doesn't need a framework, it doesn't get one.
                  <span class="hero__highlight">Static stays static.</span>
                  The right tool for the right job, always.
                </p>
              </div>

              <p class="hero__manifesto-text">
                Cut my teeth in agencies building sites for Google, then Meta. And now I
                bring that experience to bold, boundary-pushing projects of all sizes.
                I don't build "solutions"—I build experiences that actually feel something.
              </p>

              <div class="hero__tape-tag">
                <span></span>
              </div>

              <div class="hero__cta-wrap">
                <BigCta rotation="-2deg" type="secondary" text="LINKEDIN" href="https://linkedin.com/in/simonattfield" />
                <BigCta rotation="2deg" type="secondary" text="WORK" href="/work" />
                <BigCta rotation="-4deg" type="secondary" text="ABOUT" href="/about" />
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Contextual Card -->
        <div class="hero__right">
          <div class="hero__location">
            <div class="hero__location-header">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">location_on</span>
              <span class="hero__location-label">CURRENT BASE</span>
            </div>
            <p class="hero__location-city">DC METRO AREA / REMOTE</p>
          </div>

          <div class="hero__portrait">
            <img
              src="/guitar.jpg"
              alt="Digital punk aesthetic"
              class="hero__portrait-img"
            />
            <div class="hero__portrait-halftone"></div>
            <div class="hero__portrait-caption">IMG_9042_XEROX</div>
          </div>
        </div>
      </div>

      <!-- Bento Grid -->
      <div class="bento">

        <!-- Large feature card -->
        <div class="bento__feature">
          <div class="bento__feature-bg">
            <img
              src="glitch-art.png"
              alt="Abstract chaos glitch art"
            />
          </div>
          <div class="bento__feature-content">
            <h3 class="bento__feature-title">The Code is the Message</h3>
            <p class="bento__feature-body">
              Breaking pre-conceived notions of what a "button" should look like.
              No frameworks for the soul.
            </p>
          </div>
          <span class="bento__feature-number" aria-hidden="true">001</span>
        </div>

        <!-- Manifesto card -->
        <div class="bento__manifesto">
          <span
            class="material-symbols-outlined bento__manifesto-icon"
            style="font-variation-settings: 'FILL' 1"
          >warning</span>
          <div>
            <h4 class="bento__manifesto-title">MANIFESTO</h4>
            <ul class="bento__manifesto-list">
              <li>- NO COMFORT ZONES</li>
              <li>- ACCESSIBILITY IS NON-NEGOTIABLE</li>
              <li>- PERFECTION IS THE ENEMY</li>
              <li>- RAW &gt; POLISHED</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Decorative background words -->
  <!-- <div class="decor-word decor-word--no" aria-hidden="true">NO</div>
  <div class="decor-word decor-word--yes" aria-hidden="true">YES</div> -->

</Layout>

<style>
  /* ============================================================
     UTILITIES (page-scoped)
     ============================================================ */

  /* Halftone dot pattern — used as overlay on coloured surfaces */
  .halftone {
    background-image: radial-gradient(var(--color-on-surface) 1px, transparent 0);
    background-size: 4px 4px;
    opacity: 0.1;
  }

  /* ============================================================
     HERO
     ============================================================ */

  .hero {
    position: relative;
  }

  .hero__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 10;
  }

  /* Two-column flex layout */
  .hero__grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: flex-start;

    @media (min-width: 768px) {
      flex-direction: row;
    }
  }

  /* ── Left column ─────────────────────────────────────────── */

  .hero__left {
    width: 100%;
    position: relative;

    @media (min-width: 768px) {
      width: 75%;
    }
  }

  /* Decorative tape strip behind the name */
  .hero__tape-strip {
    position: absolute;
    top: -2.8rem;
    left: -2rem;
    width: 12rem;
    height: 3rem;
    background-color: var(--color-primary-fixed);
    opacity: 0.85;
    transform: rotate(-3deg);
    z-index: 11;
  }

  /* Name heading */
  .hero__name {
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 22vw;
    line-height: 0.8;
    letter-spacing: -0.05em;
    color: var(--color-on-background);
    position: relative;
    z-index: 10;
    margin: 0;

    @media (min-width: 768px) {
      font-size: min(15vw, 13.5rem);
    }
  }

  /* "SIMON" — inverted block, distorted */
  .hero__name-first {
    display: inline-block;
    transform: rotate(var(--rot)) scale(1.1) skewX(-4deg);
    background-color: var(--color-on-background);
    color: var(--color-surface);
    padding: 0.5rem 1rem;
  }

  /* "ATTFIELD" — secondary colour, slight tilt */
  .hero__name-last {
    display: inline-block;
    transform: rotate(var(--rot));
    color: var(--color-secondary);
    margin-top: -1rem;
  }

  /* Ethos block wrapper — slight clockwise tilt */
  .hero__ethos-block {
    margin-top: 3rem;
    max-width: 42rem;
    transform: rotate(1deg);
  }

  /* Yellow primary-container card with heavy left border */
  .hero__ethos-inner {
    background-color: var(--color-primary-container);
    padding: 1.5rem;
    border-left: 12px solid var(--color-on-background);
    position: relative;
  }

  /* Halftone overlay inside ethos card */
  .hero__halftone {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--color-on-surface) 1px, transparent 0);
    background-size: 4px 4px;
    opacity: 0.1;
    pointer-events: none;
  }

  .hero__sub-headline {
    font-family: var(--font-headline);
    font-size: 2.25rem;
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    line-height: 1;
    margin: 0 0 1rem;
    position: relative;

    @media (min-width: 768px) {
      font-size: 3.75rem;
    }
  }

  /* Xerox effect block — high contrast, torn edges */
  .hero__xerox-block {
    margin: 2rem 0;
    transform: rotate(-2deg);
    padding: 2rem;
    border: 2px solid #000;
    position: relative;
    overflow: hidden;

    /* Xerox effect: high contrast greyscale with hard block shadow */
    filter: contrast(200%) brightness(150%) grayscale(100%);
    background-color: #fff;
    color: #000;
    box-shadow: 1px 1px 0px #000, 2px 2px 0px #000;

    /* Torn paper left/right edges via clip-path */
    clip-path: polygon(
      0% 0%, 100% 0%,
      98% 10%, 100% 21%, 97% 32%, 100% 45%,
      98% 56%, 100% 68%, 97% 82%, 100% 91%,
      96% 100%, 0% 100%,
      2% 88%, 0% 77%, 4% 65%, 1% 54%,
      3% 42%, 0% 31%, 2% 19%, 0% 9%
    );
  }

  /* Yellow tint overlay inside xerox block */
  .hero__xerox-tint {
    position: absolute;
    inset: 0;
    background-color: #facc15;
    mix-blend-mode: multiply;
    opacity: 0.2;
    pointer-events: none;
  }

  .hero__xerox-title {
    font-family: var(--font-headline);
    font-size: 1.875rem;
    font-weight: 900;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    border-bottom: 4px solid #000;
    display: inline-block;
  }

  .hero__xerox-body {
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.25;
    font-weight: 700;
    margin: 1rem 0 0;

    @media (min-width: 768px) {
      font-size: 1.5rem;
    }
  }

  /* Inline highlight — black bg / white text */
  .hero__highlight {
    background-color: #000;
    color: #fff;
    padding: 0 0.25rem;
  }

  .hero__manifesto-text {
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.625;
    font-style: italic;
    margin: 0 0 2rem;
    position: relative;

    @media (min-width: 768px) {
      font-size: 1.5rem;
    }
  }

  /* "NON-CONFORMIST" tape tag — overlaps top-right corner */
  .hero__tape-tag {
    position: absolute;
    top: -1rem;
    right: -2rem;
    width: 8rem;
    height: 2.5rem;
    background-color: var(--color-secondary-container);
    opacity: 0.8;
    transform: rotate(12deg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__tape-tag span {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-on-secondary-container);
  }

  .hero__cta-wrap {
    margin-top: 2rem;
  }

  .hero__cta {
    display: inline-block;
    background-color: var(--color-on-background);
    color: var(--color-surface);
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 1.5rem;
    padding: 0.75rem 1.5rem;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    text-decoration: none;
    transform: rotate(-1deg);
    transition: background-color 150ms, color 150ms, transform 150ms;

    &:hover {
      background-color: var(--color-secondary);
      color: #fff;
      transform: rotate(0deg);
    }
  }

  /* ── Right column ────────────────────────────────────────── */

  .hero__right {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    @media (min-width: 768px) {
      width: 25%;
    }
  }

  /* Location card */
  .hero__location {
    background-color: var(--color-surface-container-highest);
    padding: 1rem;
    border: 2px solid var(--color-on-background);
    transform: rotate(-2deg);
    box-shadow: 4px 4px 0px var(--color-on-surface);
  }

  .hero__location-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .hero__location-label {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
  }

  .hero__location-city {
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 1.25rem;
    margin: 0;
  }

  /* Portrait image scrap */
  .hero__portrait {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: var(--color-on-surface);
    overflow: hidden;
    border: 4px solid #fff;
    transform: rotate(3deg);
    box-shadow: 12px 12px 0px var(--color-primary-container);
  }

  .hero__portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: screen;
    opacity: 0.6;
    filter: sepia(1.3) grayscale(0.5) contrast(1.2);
  }

  .hero__portrait-halftone {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--color-on-surface) 1px, transparent 0);
    background-size: 4px 4px;
    opacity: 0.1;
    pointer-events: none;
  }

  .hero__portrait-caption {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background-color: #fff;
    color: #000;
    font-family: var(--font-label);
    font-weight: 900;
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    text-transform: uppercase;
  }

  /* ============================================================
     BENTO GRID
     ============================================================ */

  .bento {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;

    @media (min-width: 768px) {
      grid-template-columns: repeat(12, 1fr);
    }
  }

  /* Large feature card — 8 of 12 columns */
  .bento__feature {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 400px;
    background-color: var(--color-surface-container-low);
    padding: 2rem;

    @media (min-width: 768px) {
      grid-column: span 8;
    }
  }

  .bento__feature-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    filter: grayscale(1);
    opacity: 0.2;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .bento__feature-content {
    position: relative;
    z-index: 10;
    max-width: 36rem;
  }

  .bento__feature-title {
    font-family: var(--font-headline);
    font-size: 3rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 1.5rem;
  }

  .bento__feature-body {
    font-family: var(--font-body);
    font-size: 1.5rem;
    background-color: var(--color-on-background);
    color: var(--color-surface);
    line-height: 1.6;
    display: inline;
    padding: 0.5rem;
    /* Clone box-decoration so bg continues across line breaks */
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    margin: 0;
  }

  /* Large decorative number — sits behind content */
  .bento__feature-number {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 8rem;
    line-height: 1;
    color: rgba(45, 47, 44, 0.2);
    z-index: -1;
    user-select: none;
  }

  /* Manifesto card — 4 of 12 columns */
  .bento__manifesto {
    background-color: var(--color-secondary);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transform: rotate(-1deg);
    box-shadow: 8px 8px 0px var(--color-on-surface);

    @media (min-width: 768px) {
      grid-column: span 4;
    }
  }

  .bento__manifesto-icon {
    color: #fff;
    font-size: 3rem;
  }

  .bento__manifesto-title {
    font-family: var(--font-headline);
    font-size: 1.875rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1rem;
    text-decoration: underline;
    text-decoration-thickness: 4px;
  }

  .bento__manifesto-list {
    font-family: var(--font-label);
    font-size: 0.875rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ============================================================
     DECORATIVE BACKGROUND WORDS
     ============================================================ */

  .decor-word {
    position: fixed;
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 30rem;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    opacity: 0.05;
  }

  .decor-word--no {
    top: 25%;
    right: -5rem;
  }

  .decor-word--yes {
    bottom: 25%;
    left: -5rem;
  }
</style>
