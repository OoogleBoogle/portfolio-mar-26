---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  activePage?: 'home' | 'work' | 'about';
}

const { title = 'Simon Attfield', description = 'Front-end developer. 8+ years.', activePage } = Astro.props;
const canonicalUrl = Astro.url.href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Primary meta -->
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <title>{title}</title>

    <!-- Page-level schema and additional head tags -->
    <slot name="head" />
    <Font cssVariable="--font-headline" preload />
    <Font cssVariable="--font-body" preload />
  </head>
  <body class={activePage === 'home' ? 'layout-body' : ''}>
    <!-- Xerox grain: global noise filter that kills digital flatness -->
     <div class="grain-overlay" aria-hidden="true"></div>
    <!-- {activePage !== 'home' && } -->
    <!-- {activePage === 'home' && } -->
    <!-- <div class="repeating-graphic" /> -->

    <Nav activePage={activePage} />

    <main class="layout-main">
      <slot />
    </main>

    <Footer>
      <slot name="footer-decoration" />
    </Footer>
  </body>
  <script>
    // On navigation: pause entrance animations while the exit plays,
    // then release them once the view transition finishes so they play
    // on the real elements (not the pseudo-element screenshots).
    window.addEventListener('pagereveal', async (e) => {
      await document.fonts.ready;
      if ((e as any).viewTransition) {
        document.documentElement.classList.add('vt-transitioning');

        // Safety net: always release .vt-enter after 2.5s even if the promise stalls.
        const fallback = setTimeout(() => {
          document.documentElement.classList.remove('vt-transitioning');
        }, 2500);

        try {
          await (e as any).viewTransition.finished;
        } finally {
          clearTimeout(fallback);
          // Pseudo-elements handled the visual entry — suppress .vt-enter re-animation.
          // vt-navigated is never explicitly removed: it clears automatically on the next
          // navigation because cross-document transitions replace <html> entirely.
          document.documentElement.classList.add('vt-navigated');
          document.documentElement.classList.remove('vt-transitioning');
        }
      }
    });
  </script>
</html>

<style>
  .layout-body {
    position: relative;
  }
  /* ── Grain overlay ───────────────────────────────────────── */

  .grain-overlay {
    /* position: absolute;
    inset: 0;
    pointer-events: none; */
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none;
    z-index: 60;
    opacity: 0.1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    /* z-index: 9999; */
    /* opacity: 0.04; */

    height: 100%;
  }

  .repeating-graphic {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: url("/grain-texture.png");
  }

  /* ── Body ────────────────────────────────────────────────── */

  :global(body) {
    overflow-x: hidden;
  }

  /* ── Main content area ───────────────────────────────────── */

  .layout-main {
    /* Push content below the fixed nav (4rem) with extra breathing room */
    padding-top: 15rem;
    padding-bottom: 6rem;
  }

</style>
